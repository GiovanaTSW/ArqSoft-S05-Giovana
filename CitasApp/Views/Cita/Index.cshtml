@using CitasApp
@using CitasApp.Domain.Models

@{
    var pacientes = ViewBag.Pacientes as List<Paciente>;
    var medicos = ViewBag.Medicos as List<Medico>;
}

<div style="background: linear-gradient(135deg, #3a9ea5 0%, #2b7a80 100%); border-radius: 16px; padding: 40px; text-align: center; margin-bottom: 40px;">
    <h1 style="color: white; font-size: 2.2rem; font-weight: 700; margin-bottom: 10px;">Citas</h1>
    <p style="color: rgba(255,255,255,0.85); font-size: 1rem; margin: 0;">Agenda completa de citas médicas</p>
</div>

<div style="margin-bottom: 24px;">
    <a asp-action="AgregarCita" style="background: #3a9ea5; border: none; color: white; border-radius: 8px; padding: 10px 28px; font-weight: 600; text-decoration: none;">
        + Agregar nueva cita
    </a>
</div>

<div style="background: white; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); overflow: hidden;">
    <table style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr style="background: #e8f7f8;">
                <th style="padding: 14px 20px; text-align: left; color: #2b7a80; font-weight: 700;">Fecha</th>
                <th style="padding: 14px 20px; text-align: left; color: #2b7a80; font-weight: 700;">Hora</th>
                <th style="padding: 14px 20px; text-align: left; color: #2b7a80; font-weight: 700;">Paciente</th>
                <th style="padding: 14px 20px; text-align: left; color: #2b7a80; font-weight: 700;">Médico</th>
                <th style="padding: 14px 20px; text-align: left; color: #2b7a80; font-weight: 700;">Motivo</th>
                <th style="padding: 14px 20px; text-align: left; color: #2b7a80; font-weight: 700;">Estado</th>
                <th style="padding: 14px 20px;"></th>
                <th style="padding: 14px 20px;"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                var paciente = pacientes?.FirstOrDefault(p => p.Id == c.PacienteId);
                var medico = medicos?.FirstOrDefault(m => m.Id == c.MedicoId);
                <tr style="border-top: 1px solid #f0f0f0;">
                    <td style="padding: 14px 20px; color: #333;">@c.Fecha.ToString("dd/MM/yyyy")</td>
                    <td style="padding: 14px 20px; color: #333;">@c.Hora.ToString("HH:mm")</td>
                    <td style="padding: 14px 20px; font-weight: 600; color: #333;">@(paciente != null ? $"{paciente.Nombre} {paciente.Apellido}" : "—")</td>
                    <td style="padding: 14px 20px; color: #6c757d;">@(medico != null ? $"{medico.Nombre} {medico.Apellido}" : "—")</td>
                    <td style="padding: 14px 20px; color: #6c757d;">@c.Motivo</td>
                    <td style="padding: 14px 20px;">
                        @if (c.Estado == "Confirmada")
                        {
                            <span style="background: #e8f7f8; color: #2b7a80; border-radius: 20px; padding: 4px 12px; font-size: 0.85rem; font-weight: 600;">Confirmada</span>
                        }
                        else if (c.Estado == "Cancelada")
                        {
                            <span style="background: #fde8e8; color: #c0392b; border-radius: 20px; padding: 4px 12px; font-size: 0.85rem; font-weight: 600;">Cancelada</span>
                        }
                        else
                        {
                            <span style="background: #fff8e8; color: #b07d00; border-radius: 20px; padding: 4px 12px; font-size: 0.85rem; font-weight: 600;">Pendiente</span>
                        }
                    </td>
                    <td style="padding: 14px 20px;">
                        <a asp-action="Editar" asp-route-id="@c.Id" style="background: #e8f7f8; color: #2b7a80; border-radius: 6px; padding: 6px 16px; font-weight: 600; text-decoration: none;">
                            Editar
                        </a>
                    </td>
                    <td style="padding: 14px 20px;">
                        <a asp-action="Eliminar" asp-route-id="@c.Id" style="background: #fde8e8; color: #c0392b; border-radius: 6px; padding: 6px 16px; font-weight: 600; text-decoration: none;">
                            Eliminar
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div style="margin-top: 24px;">
    <a asp-controller="Home" asp-action="Index" style="color: #3a9ea5; font-weight: 600; text-decoration: none;">
        ← Volver al menú
    </a>
</div>