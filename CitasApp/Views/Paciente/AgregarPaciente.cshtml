@model CitasApp.Models.Paciente

<h1>Agregar nuevo paciente</h1>

<form asp-action="AgregarPaciente" method="post" style="max-width:400px">
    <div>
        <label asp-for="Nombre">Nombre</label>
        <input asp-for="Nombre" />
        <span asp-validation-for="Nombre"></span>
    </div>
    <div>
        <label asp-for="Apellido">Apellido</label>
        <input asp-for="Apellido" />
        <span asp-validation-for="Apellido"></span>
    </div>
    <div>
        <label asp-for="Email">Email</label>
        <input asp-for="Email" />
        <span asp-validation-for="Email"></span>
    </div>
    <div>
        <label asp-for="Telefono">Teléfono</label>
        <input asp-for="Telefono" />
        <span asp-validation-for="Telefono"></span>
    </div>
    <br />
    <button type="submit">Guardar</button>
    <a asp-action="Index">← Cancelar</a>
</form>