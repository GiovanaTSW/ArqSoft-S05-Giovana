@{
    ViewData["Title"] = "Política de Privacidad";
}

<div style="background: linear-gradient(135deg, #3a9ea5 0%, #2b7a80 100%); border-radius: 16px; padding: 60px 40px; text-align: center; margin-bottom: 40px;">
    <h1 style="color: white; font-size: 2.8rem; font-weight: 700; margin-bottom: 10px;">Política de Privacidad</h1>
    <p style="color: rgba(255,255,255,0.85); font-size: 1.2rem; margin: 0;">Cómo manejamos tu información en CitasApp</p>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div style="background: white; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); padding: 36px 28px; height: 100%;">
            <div style="background: #e8f7f8; border-radius: 50%; width: 70px; height: 70px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                <span style="color: #2b7a80; font-size: 1.8rem; font-weight: 700;">D</span>
            </div>
            <h4 style="font-weight: 700; margin-bottom: 10px; color: #2b7a80;">Datos que recopilamos</h4>
            <p style="color: #6c757d;">
                Recopilamos únicamente los datos necesarios para el funcionamiento de la aplicación:
                nombre, apellido, correo electrónico y teléfono de los pacientes; y nombre, apellido,
                especialidad y número de licencia de los médicos.
            </p>
        </div>
    </div>
    <div class="col-md-6">
        <div style="background: white; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); padding: 36px 28px; height: 100%;">
            <div style="background: #e8f7f8; border-radius: 50%; width: 70px; height: 70px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                <span style="color: #2b7a80; font-size: 1.8rem; font-weight: 700;">U</span>
            </div>
            <h4 style="font-weight: 700; margin-bottom: 10px; color: #2b7a80;">Uso de la información</h4>
            <p style="color: #6c757d;">
                La información recopilada se utiliza exclusivamente para gestionar citas médicas
                dentro de la plataforma. No se comparte con terceros ni se usa con fines comerciales.
            </p>
        </div>
    </div>
    <div class="col-md-6">
        <div style="background: white; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); padding: 36px 28px; height: 100%;">
            <div style="background: #e8f7f8; border-radius: 50%; width: 70px; height: 70px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                <span style="color: #2b7a80; font-size: 1.8rem; font-weight: 700;">A</span>
            </div>
            <h4 style="font-weight: 700; margin-bottom: 10px; color: #2b7a80;">Almacenamiento</h4>
            <p style="color: #6c757d;">
                Los datos se almacenan en archivos locales del servidor. No se utilizan bases de datos
                externas ni servicios en la nube para guardar información personal.
            </p>
        </div>
    </div>
    <div class="col-md-6">
        <div style="background: white; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); padding: 36px 28px; height: 100%;">
            <div style="background: #e8f7f8; border-radius: 50%; width: 70px; height: 70px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                <span style="color: #2b7a80; font-size: 1.8rem; font-weight: 700;">C</span>
            </div>
            <h4 style="font-weight: 700; margin-bottom: 10px; color: #2b7a80;">Contacto</h4>
            <p style="color: #6c757d;">
                Si tienes preguntas sobre el manejo de tus datos, puedes comunicarte con el
                administrador del sistema.
            </p>
        </div>
    </div>
</div>